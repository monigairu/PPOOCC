GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global
VERTEX_SEARCH_F2_DATASTORE_ID=nuro-f2-knowledge
VERTEX_SEARCH_F3_DATASTORE_ID=nuro-f3-knowledge
VERTEX_SEARCH_F2_ENGINE_ID=nuro-f2-search
VERTEX_SEARCH_F3_ENGINE_ID=nuro-f3-search

# ── Langfuse（RAGトレーシング・エンジニア向け） ──────────────
# ローカル: docker compose -f docker-compose.langfuse.yml up -d
# その後 http://localhost:3000 でUIを確認
# キーは http://localhost:3000 → Settings → API Keys で発行する
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

GOOGLE_APPLICATION_CREDENTIALS=./your-service-account-key.json
GCS_BUCKET_NAME=your-gcs-bucket-name
